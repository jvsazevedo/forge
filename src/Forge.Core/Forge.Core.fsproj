<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- Required for P/Invoke to locate the native .so on Linux -->
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <AssemblyName>ForgeCore</AssemblyName>
    <RootNamespace>ForgeCore</RootNamespace>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Generated/FurstBindings.fs" />
    <Compile Include="Lib.fs" />
  </ItemGroup>

</Project>
